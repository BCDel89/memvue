# =============================================================================
# MemVue — Environment Configuration
# cp .env.example .env  →  fill in your values  →  docker compose up -d
# =============================================================================

# -----------------------------------------------------------------------------
# mem0 (required for the All tab and sync features)
# Cloud:       https://app.mem0.ai  →  Settings → API Keys
# Self-hosted: http://localhost:8888  (OpenMemory / mem0-server)
# -----------------------------------------------------------------------------
MEM0_URL=https://api.mem0.ai
MEM0_API_KEY=

# User/workspace to scope memories under (maps to mem0 user_id)
MEM0_USER_ID=default

# -----------------------------------------------------------------------------
# Filesystem adapter (required for the Files tab)
# Comma-separated absolute paths to directories MemVue should scan.
# Inside Docker: mount these same paths as volumes below.
# Example: FS_ROOTS=/Users/me/.claude,/Users/me/notes
# -----------------------------------------------------------------------------
FS_ROOTS=/data

# File extensions to include (comma-separated)
FS_EXTENSIONS=.md,.txt

# Directories to skip (comma-separated partial names, merged with built-in defaults)
# FS_EXCLUDE_DIRS=node_modules,.git,dist,.cache

# Max depth to recurse into directories
# FS_MAX_DEPTH=6

# -----------------------------------------------------------------------------
# LLM (optional — enables smart tagging, ingest, digest, and proactive suggestions)
# Provider options:  ollama | openai_compatible | anthropic
# Ollama example:    LLM_PROVIDER=ollama  LLM_BASE_URL=http://host.docker.internal:11434  LLM_MODEL=gemma3:4b
# Anthropic example: LLM_PROVIDER=anthropic  LLM_API_KEY=sk-ant-...  LLM_MODEL=claude-haiku-4-5-20251001
# OpenRouter example: LLM_PROVIDER=openai_compatible  LLM_BASE_URL=https://openrouter.ai/api  LLM_API_KEY=sk-or-...  LLM_MODEL=meta-llama/llama-3.3-8b-instruct:free
# -----------------------------------------------------------------------------
LLM_PROVIDER=
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# -----------------------------------------------------------------------------
# App settings
# -----------------------------------------------------------------------------
# Lock the API with a key — must match the API Key field in Settings (leave empty to disable auth)
# MEMVUE_API_KEY=changeme

# Label shown on the root node in the Graph view
# AGENT_NAME=agent

# Entry-point files for the graph (comma-separated filenames)
# GRAPH_ENTRY_POINTS=MEMORY.md,CLAUDE.md

# CORS origins (comma-separated, or * to allow all)
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com
