# mem0 adapter
MEM0_URL=http://localhost:8000
MEM0_API_KEY=your-mem0-api-key
MEM0_USER_ID=default

# filesystem adapter (comma-separated paths)
FS_ROOTS=/path/to/notes,/path/to/docs
FS_EXTENSIONS=.md,.txt

# filesystem scan options
# FS_EXCLUDE_DIRS=my-private-dir,secrets     # extra dirs to skip (merged with defaults)
# FS_MAX_DEPTH=6                              # max directory traversal depth

# graph view
# AGENT_NAME=agent                           # label shown on the root node
# GRAPH_ENTRY_POINTS=MEMORY.md,CLAUDE.md     # filenames to show as level-1 nodes

# cors (comma-separated origins, or * to allow all)
# CORS_ORIGINS=http://localhost:5173,https://yourdomain.com

# optional: lock down the memvue API
# MEMVUE_API_KEY=changeme
